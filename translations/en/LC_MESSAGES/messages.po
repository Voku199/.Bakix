#: app/templates/payment_success.html:12
msgid "Premium aktivováno!"
msgstr "Premium activated!"

#: app/templates/payment_success.html:14
msgid "Děkujeme za podporu. Máš teď 50 AI dotazů denně."
msgstr "Thank you for your support. You now have 50 AI queries per day."

#: app/templates/payment_success.html:18
msgid "Platí do"
msgstr "Valid until"

#: app/templates/payment_success.html:23
msgid "Platba se zpracovává"
msgstr "Payment processing"

#: app/templates/payment_success.html:25
msgid "Jakmile platbu potvrdíme, Premium se ti aktivuje automaticky."
msgstr "Once we confirm your payment, Premium will activate automatically."

#: app/templates/welcome.html:64
msgid ""
"Přehledný dashboard pro vaše Bakaláře. Známky, rozvrh a suplování — "
"přístupné, krásné, chytré."
msgstr ""
"A clean dashboard for Bakaláře. Grades, schedule, and substitutions — "
"accessible, beautiful, smart."

#: app/templates/welcome.html:69 app/templates/welcome.html:165
msgid "Začít zdarma"
msgstr "Get started free"

#: app/templates/welcome.html:72
msgid "Demo verze"
msgstr "Demo version"

